# Django Configuration
SECRET_KEY=your-secret-key-here
DEBUG=True

# Database Configuration (Neon PostgreSQL)
DATABASE_PASSWORD=your-neon-db-password
DATABASE_HOST=your-neon-db-host

# AI API Keys
GROQ_API_KEY=your-groq-api-key-here
OPENAI_API_KEY=your-openai-api-key-here  # Optional, for enhanced RAG responses

# Pinecone Configuration for RAG
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=asmit-portfolio-rag

# Optional: Custom model configurations
# EMBEDDING_MODEL=all-MiniLM-L6-v2
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200

# Rate Limiting Configuration
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORE=redis
RATE_LIMIT_FAIL_OPEN=true

# Redis Cache URL (Required if RATE_LIMIT_STORE=redis)
# REDIS_URL=redis://127.0.0.1:6379/1

# Optional Custom Rate Limits (in milliseconds and max requests)
RATE_LIMIT_PUBLIC_WINDOW_MS=900000
RATE_LIMIT_PUBLIC_MAX=100
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_LOGIN_FAILED_MAX=5
RATE_LIMIT_LOGIN_BACKOFF_BASE_SECONDS=30
RATE_LIMIT_LOGIN_BACKOFF_MAX_SECONDS=1800
RATE_LIMIT_CONTACT_WINDOW_MS=3600000
RATE_LIMIT_CONTACT_MAX=5
RATE_LIMIT_CHAT_ANONYMOUS_WINDOW_MS=600000
RATE_LIMIT_CHAT_ANONYMOUS_MAX=10
RATE_LIMIT_CHAT_AUTHENTICATED_WINDOW_MS=600000
RATE_LIMIT_CHAT_AUTHENTICATED_MAX=30
RATE_LIMIT_AUTHENTICATED_WINDOW_MS=900000
RATE_LIMIT_AUTHENTICATED_MAX=300
RATE_LIMIT_EXPENSIVE_WINDOW_MS=3600000
RATE_LIMIT_EXPENSIVE_MAX=10